# Upshot web — environment template. Copy to .env and fill in real values.
# NEVER commit a real .env (it is gitignored). This file holds placeholders only.

# Encryption key for the at-rest SQLCipher database. Required at boot.
# Generate a strong random value (32+ chars), e.g. `openssl rand -base64 32`.
DB_ENCRYPTION_KEY=

# better-auth signing secret. Required. Generate, e.g. `openssl rand -base64 32`.
BETTER_AUTH_SECRET=

# Base URL where auth registrations/authentications occur. No trailing slash.
# Dev default below; the WebAuthn origin is derived from this.
BETTER_AUTH_URL=http://localhost:3000

# WebAuthn Relying Party ID. Must equal, or be a registrable parent (with a
# dot) of, the BETTER_AUTH_URL hostname. Dev uses "localhost".
UPSHOT_RP_ID=localhost

# Client-side base URL (exposed to the browser). Optional: if omitted the auth
# client falls back to same-origin. Set it to the same value as BETTER_AUTH_URL.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# --- Tailscale production example (uncomment + adjust for your tailnet) ---
# BETTER_AUTH_URL=https://upshot.<tailnet>.ts.net
# UPSHOT_RP_ID=upshot.<tailnet>.ts.net
# NEXT_PUBLIC_BETTER_AUTH_URL=https://upshot.<tailnet>.ts.net
