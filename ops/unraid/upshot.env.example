# Copy to ops/unraid/upshot.env on the server and fill in. NEVER commit the real file.
NODE_ENV=production
# --- ports ---
WEB_HOST_PORT=3033
# --- data ---
UPSHOT_DATA_DIR=/mnt/user/appdata/upshot
DATABASE_URL=/data/upshot.db
# --- secrets (generate fresh) ---
DB_ENCRYPTION_KEY=        # openssl rand -hex 32   (LOST KEY = UNRECOVERABLE DATA)
BETTER_AUTH_SECRET=       # openssl rand -hex 32
UP_API_TOKEN=             # up:yeah:...
# --- public URLs / RP-ID (must equal the NPM hostname, HTTPS) ---
BETTER_AUTH_URL=https://upshot.example.com
NEXT_PUBLIC_BETTER_AUTH_URL=https://upshot.example.com
UPSHOT_RP_ID=upshot.example.com
SERVER_ACTIONS_ALLOWED_ORIGINS=upshot.example.com
